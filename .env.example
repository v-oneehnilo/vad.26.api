# Public show-control backend
NODE_ENV=development
PORT=4300
SHOW_STATE_PATH=./data/show-state.json

# Optional shared token for mutating REST/WS requests.
# Leave empty for open local debugging.
CONTROL_TOKEN=

# Firebase Admin SDK configuration for backend integrations.
# Prefer GOOGLE_APPLICATION_CREDENTIALS for local service account files.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# Firebase Web SDK configuration for browser-based modules if needed.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public backend URLs for local modules and future adapters.
VITE_SHOW_BACKEND_URL=http://localhost:4300
VITE_SHOW_WS_URL=ws://localhost:4300/ws
VITE_CONTROL_TOKEN=
